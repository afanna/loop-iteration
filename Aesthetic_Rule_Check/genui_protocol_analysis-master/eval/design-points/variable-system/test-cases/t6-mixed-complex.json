[
  {
    "id": "VS051",
    "name": "综合-全部变量类型在同一组件",
    "category": "t6-mixed-complex",
    "complexity": "complex",
    "task": "生成一个Extended.Column，包含：1.Text显示$__DataModel.app.title（DataModel绝对路径）2.List数据/users模板显示$name和$index+1（相对路径+内置变量）3.Button点击时validate(as='vResult')后根据$vResult和$__WidthBreakpoint决定下一步（as绑定+全局变量+DataModel）",
    "expected": {
      "component": "Extended.Column",
      "required_fields": [
        "component",
        "children"
      ],
      "patterns": [
        {
          "field": "children",
          "must_be_array": true
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "children",
        "description": "Column有children数组"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__DataModel.app.title",
        "description": "引用DataModel绝对路径"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "Extended.List",
        "description": "包含List组件"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$name",
        "description": "List模板使用相对路径"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$index",
        "description": "List模板使用$index"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "as",
        "description": "Button有as绑定"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__WidthBreakpoint",
        "description": "引用全局变量"
      }
    ],
    "hints": [
      "所有变量类型可共存于一个组件树",
      "每种变量使用对应前缀"
    ]
  },
