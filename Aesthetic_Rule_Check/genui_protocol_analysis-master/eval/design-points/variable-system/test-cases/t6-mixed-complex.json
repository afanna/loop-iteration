  {
    "id": "VS055",
    "name": "综合-多事件+多变量源+条件分支",
    "category": "t6-mixed-complex",
    "complexity": "complex",
    "task": "生成一个Extended.Button：onClick时1.validate(as='vR')2.若$vR==0则submitData传$__DataModel.formData 3.若$vR!=0则sendToLLM传$context.componentId。onAppear时checkInit(as='initR')，根据$initR和$__WidthBreakpoint设置初始状态",
    "expected": {
      "component": "Extended.Button",
      "required_fields": [
        "component",
        "onAppear",
        "onClick"
      ],
      "patterns": [
        {
          "field": "onClick",
          "must_be_array": true
        },
        {
          "field": "onAppear",
          "must_be_array": true
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "onClick",
        "description": "必须有onClick"
      },
      {
        "type": "has_field",
        "field": "onAppear",
        "description": "必须有onAppear"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$vR",
        "description": "onClick中as变量$vR"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__DataModel.formData",
        "description": "引用DataModel"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$context.componentId",
        "description": "引用$context"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$initR",
        "description": "onAppear中as变量$initR"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__WidthBreakpoint",
        "description": "引用全局变量"
      }
    ],
    "hints": [
      "不同事件有独立as作用域",
      "as变量、DataModel、$context、全局变量可在同一组件中共存"
    ]
  },
