  {
    "id": "VS045",
    "name": "同名冲突-as绑定名与其他as绑定重叠",
    "category": "t5-conflict",
    "complexity": "complex",
    "task": "生成一个Extended.Button，点击时三步：1.validate(as='result') 2.process(as='result')覆盖前值 3.condition判断$result==0时调用finish。注意第二步as同名覆盖第一步",
    "expected": {
      "component": "Extended.Button",
      "required_fields": [
        "component",
        "onClick"
      ],
      "patterns": [
        {
          "field": "onClick",
          "must_be_array": true
        },
        {
          "field": "onClick",
          "must_have_length": 3
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "onClick",
        "description": "必须有onClick事件"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "validate",
        "description": "第一步validate"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "process",
        "description": "第二步process"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "result",
        "description": "两次as绑定同名result"
      }
    ],
    "hints": [
      "后执行的as绑定会覆盖同名的前置as变量",
      "$result引用的是最近一次as绑定的值"
    ],
    "is_edge": true
  },
