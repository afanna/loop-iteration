[
  {
    "id": "VS041",
    "name": "同名冲突-as绑定与DataModel字段同名",
    "category": "t5-conflict",
    "complexity": "complex",
    "task": "生成一个Extended.Button，DataModel中有count字段。点击时先调用increment(as='count')，然后condition判断$count==0且$__DataModel.count>3时调用submit",
    "expected": {
      "component": "Extended.Button",
      "required_fields": [
        "component",
        "onClick"
      ],
      "patterns": [
        {
          "field": "onClick",
          "must_be_array": true
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "onClick",
        "description": "必须有onClick事件"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "as",
        "description": "必须有as绑定"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$count",
        "description": "as局部变量用$count引用"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__DataModel.count",
        "description": "DataModel字段用$__DataModel.count显式区分"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "submit",
        "description": "调用submit"
      }
    ],
    "hints": [
      "as变量$count和DataModel字段$__DataModel.count通过前缀区分",
      "同名时必须用绝对路径引用DataModel"
    ],
    "is_edge": true
  },
