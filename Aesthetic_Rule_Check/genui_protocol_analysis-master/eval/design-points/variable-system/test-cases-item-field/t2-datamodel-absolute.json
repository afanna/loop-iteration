[
  {
    "id": "VS007",
    "name": "DataModel简单字段引用",
    "category": "t2-datamodel-absolute",
    "complexity": "simple",
    "task": "生成一个Extended.Text组件，text显示$__DataModel.user.name的值",
    "expected": {
      "component": "Extended.Text",
      "required_fields": [
        "component",
        "content"
      ],
      "patterns": [
        {
          "field": "content",
          "must_contain": "$__DataModel"
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "content",
        "description": "必须有content字段"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__DataModel.user.name",
        "description": "必须使用$__DataModel.user.name绝对路径引用"
      }
    ],
    "hints": [
      "DataModel使用$__DataModel前缀绝对路径引用",
      "表达式用{{ }}包裹"
    ]
  },
  {
    "id": "VS008",
    "name": "DataModel深层嵌套属性",
    "category": "t2-datamodel-absolute",
    "complexity": "simple",
    "task": "生成一个Extended.Text组件，text显示$__DataModel.user.profile.address.city的值",
    "expected": {
      "component": "Extended.Text",
      "required_fields": [
        "component",
        "content"
      ],
      "patterns": [
        {
          "field": "content",
          "must_contain": "$__DataModel"
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "content",
        "description": "必须有content字段"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__DataModel.user.profile.address.city",
        "description": "必须使用完整绝对路径"
      }
    ],
    "hints": [
      "支持多级属性访问，用.分隔",
      "表达式用{{ }}包裹"
    ]
  },
  {
    "id": "VS009",
    "name": "DataModel方括号属性访问",
    "category": "t2-datamodel-absolute",
    "complexity": "medium",
    "task": "生成一个Extended.Text组件，text显示$__DataModel.config['api.endpoint']的值（属性名含特殊字符用方括号）",
    "expected": {
      "component": "Extended.Text",
      "required_fields": [
        "component",
        "content"
      ],
      "patterns": [
        {
          "field": "content",
          "must_contain": "$__DataModel"
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "content",
        "description": "必须有content字段"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__DataModel.config",
        "description": "必须引用$__DataModel.config"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "api.endpoint",
        "description": "必须包含属性名api.endpoint"
      }
    ],
    "hints": [
      "属性名包含特殊字符(如.)时用['xxx']方括号访问",
      "表达式用{{ }}包裹"
    ]
  },
  {
    "id": "VS010",
    "name": "DataModel在condition中",
    "category": "t2-datamodel-absolute",
    "complexity": "medium",
    "task": "生成一个Extended.Button组件，label为'提交'，enabled属性根据$__DataModel.user.canEdit的值设置（true时启用）",
    "expected": {
      "component": "Extended.Button",
      "required_fields": [
        "component",
        "label",
        "enabled"
      ],
      "patterns": [
        {
          "field": "enabled",
          "must_contain": "$__DataModel"
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "enabled",
        "description": "必须有enabled字段"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__DataModel.user.canEdit",
        "description": "enabled必须引用$__DataModel.user.canEdit"
      }
    ],
    "hints": [
      "enabled是布尔属性，表达式直接引用DataModel的布尔字段",
      "表达式用{{ }}包裹"
    ]
  },
  {
    "id": "VS011",
    "name": "DataModel在args中传递",
    "category": "t2-datamodel-absolute",
    "complexity": "medium",
    "task": "生成一个Extended.Button组件，label为'发送'，点击时调用sendToLLM，args的value传递$__DataModel.formData的值",
    "expected": {
      "component": "Extended.Button",
      "required_fields": [
        "component",
        "label",
        "onClick"
      ],
      "patterns": [
        {
          "field": "onClick",
          "must_be_array": true
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "onClick",
        "description": "必须有onClick事件"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "sendToLLM",
        "description": "必须调用sendToLLM"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__DataModel.formData",
        "description": "args中必须引用$__DataModel.formData"
      }
    ],
    "hints": [
      "EventHandler数组格式：事件名 = [{id, call, args}]",
      "args中表达式用{{ }}包裹"
    ]
  },
  {
    "id": "VS012",
    "name": "DataModel在模板字符串中",
    "category": "t2-datamodel-absolute",
    "complexity": "medium",
    "task": "生成一个Extended.Text组件，text使用模板字符串显示'用户名：$__DataModel.user.name，年龄：$__DataModel.user.age'",
    "expected": {
      "component": "Extended.Text",
      "required_fields": [
        "component",
        "content"
      ],
      "patterns": [
        {
          "field": "content",
          "must_contain": "$__DataModel"
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "content",
        "description": "必须有content字段"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__DataModel.user.name",
        "description": "模板字符串中必须引用$__DataModel.user.name"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__DataModel.user.age",
        "description": "模板字符串中必须引用$__DataModel.user.age"
      }
    ],
    "hints": [
      "模板字符串用反引号包裹，变量用${}插值",
      "表达式用{{ }}包裹"
    ]
  },
  {
    "id": "VS013",
    "name": "DataModel算术表达式",
    "category": "t2-datamodel-absolute",
    "complexity": "medium",
    "task": "生成一个Extended.Text组件，text显示$__DataModel.product.price * $__DataModel.cart.count的计算结果",
    "expected": {
      "component": "Extended.Text",
      "required_fields": [
        "component",
        "content"
      ],
      "patterns": [
        {
          "field": "content",
          "must_contain": "$__DataModel"
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "content",
        "description": "必须有content字段"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__DataModel.product.price",
        "description": "必须引用$__DataModel.product.price"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__DataModel.cart.count",
        "description": "必须引用$__DataModel.cart.count"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "*",
        "description": "必须使用乘法运算符"
      }
    ],
    "hints": [
