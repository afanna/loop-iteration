    ]
  },
  {
    "id": "VS014",
    "name": "DataModel三元表达式",
    "category": "t2-datamodel-absolute",
    "complexity": "complex",
    "task": "生成一个Extended.Text组件，text根据$__DataModel.user.vip状态显示'VIP用户'或'普通用户'",
    "expected": {
      "component": "Extended.Text",
      "required_fields": [
        "component",
        "content"
      ],
      "patterns": [
        {
          "field": "content",
          "must_contain": "$__DataModel.user.vip"
        },
        {
          "field": "content",
          "must_contain": "?"
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "content",
        "description": "必须有content字段"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__DataModel.user.vip",
        "description": "必须引用$__DataModel.user.vip"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "VIP",
        "description": "表达式应包含VIP字样"
      }
    ],
    "hints": [
      "三元表达式: condition ? trueValue : falseValue",
      "表达式用{{ }}包裹"
    ]
  }
]
