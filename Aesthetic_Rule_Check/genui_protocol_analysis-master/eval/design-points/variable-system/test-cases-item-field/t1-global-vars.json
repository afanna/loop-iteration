          "field": "space",
          "must_contain": "$__WidthBreakpoint"
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "space",
        "description": "必须有space字段"
      },
      {
        "type": "contains",
        "field": "$output",
