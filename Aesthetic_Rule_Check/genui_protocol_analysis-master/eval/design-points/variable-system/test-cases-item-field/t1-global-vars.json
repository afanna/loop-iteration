  {
    "id": "VS006",
    "name": "全局变量+DataModel同表达式混合",
    "category": "t1-global-vars",
    "complexity": "complex",
    "task": "生成一个Extended.Text组件，content显示用户$__DataModel.user.name，fontColor根据$__ColorMode设置暗色/亮色",
    "expected": {
      "component": "Extended.Text",
      "required_fields": [
        "component",
        "content",
        "styles"
      ],
      "patterns": [
        {
          "field": "content",
          "must_contain": "$__DataModel"
        },
        {
          "field": "styles.fontColor",
          "must_contain": "$__ColorMode"
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "styles",
        "description": "必须有styles对象"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__DataModel",
        "description": "content必须引用$__DataModel"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$__ColorMode",
        "description": "fontColor必须引用$__ColorMode"
      }
    ],
    "hints": [
      "全局变量$__ColorMode和DataModel变量$__DataModel是不同的变量源",
      "表达式用{{ }}包裹"
    ]
  }
]