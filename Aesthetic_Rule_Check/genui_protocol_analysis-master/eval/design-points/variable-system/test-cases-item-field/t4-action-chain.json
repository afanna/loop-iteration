[
  {
    "id": "VS031",
    "name": "as绑定-简单变量引用",
    "category": "t4-action-chain",
    "complexity": "simple",
    "task": "生成一个Extended.Button组件，label为'校验'，点击时调用validate行为，as绑定为'validResult'，然后调用sendToLLM，condition为$validResult == 0",
    "expected": {
      "component": "Extended.Button",
      "required_fields": [
        "component",
        "label",
        "onClick"
      ],
      "patterns": [
        {
          "field": "onClick",
          "must_be_array": true
        },
        {
          "field": "onClick",
          "must_have_length": 2
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "onClick",
        "description": "必须有onClick事件"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "validate",
        "description": "第一个行为调用validate"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "validResult",
        "description": "as绑定变量名为validResult"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$validResult",
        "description": "condition中引用$validResult"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "sendToLLM",
        "description": "第二个行为调用sendToLLM"
      }
    ],
    "hints": [
      "EventHandler数组格式：onClick = [{id, call, as?, args?, condition?}]",
      "as绑定创建局部变量，后续行为用$变量名引用"
    ]
  },
  {
    "id": "VS032",
