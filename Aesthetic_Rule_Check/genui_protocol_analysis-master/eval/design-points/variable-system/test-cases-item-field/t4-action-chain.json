  {
    "id": "VS038",
    "name": "as绑定-条件分支(成功/失败)",
    "category": "t4-action-chain",
    "complexity": "complex",
    "task": "生成一个Extended.Button，label为'操作'，点击时：1.validate(as='vResult') 2.若$vResult==0则setDataModel 3.若$vResult!=0则sendToLLM报错",
    "expected": {
      "component": "Extended.Button",
      "required_fields": [
        "component",
        "label",
        "onClick"
      ],
      "patterns": [
        {
          "field": "onClick",
          "must_be_array": true
        },
        {
          "field": "onClick",
          "must_have_length": 3
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "onClick",
        "description": "必须有onClick事件"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "validate",
        "description": "第一步validate"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "setDataModel",
        "description": "成功路径调用setDataModel"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "sendToLLM",
        "description": "失败路径调用sendToLLM"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "== 0",
        "description": "成功condition"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "!= 0",
        "description": "失败condition"
      }
    ],
    "hints": [
      "通过互斥的condition实现if/else分支",
      "成功$vResult==0，失败$vResult!=0"
    ]
  },
