  {
    "id": "VS035",
    "name": "as绑定-多步链式调用",
    "category": "t4-action-chain",
    "complexity": "medium",
    "task": "生成一个Extended.Button，label为'三步操作'，点击时：1.validate(as='vResult') 2.若$vResult==0则process(as='pResult') 3.若$pResult==0则sendToLLM通知成功",
    "expected": {
      "component": "Extended.Button",
      "required_fields": [
        "component",
        "label",
        "onClick"
      ],
      "patterns": [
        {
          "field": "onClick",
          "must_be_array": true
        },
        {
          "field": "onClick",
          "must_have_length": 3
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "onClick",
        "description": "必须有onClick事件"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "validate",
        "description": "第一步validate"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$vResult",
        "description": "第二步condition引用$vResult"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "process",
        "description": "第二步process"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$pResult",
        "description": "第三步condition引用$pResult"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "sendToLLM",
        "description": "第三步sendToLLM"
      }
    ],
    "hints": [
      "每个as变量作用域覆盖整个行为链",
      "condition为真执行、为假跳过"
    ]
  },
  {
