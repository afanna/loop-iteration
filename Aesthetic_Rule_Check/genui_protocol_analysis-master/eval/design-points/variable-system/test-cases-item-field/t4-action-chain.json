    "category": "t4-action-chain",
    "complexity": "simple",
    "task": "生成一个Extended.Button，label为'提交'，点击时先checkStatus(as='status')，然后condition判断$item.status.success为true时调用submitData",
    "expected": {
      "component": "Extended.Button",
      "required_fields": [
        "component",
        "label",
        "onClick"
      ],
      "patterns": [
        {
          "field": "onClick",
          "must_be_array": true
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "onClick",
        "description": "必须有onClick事件"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "checkStatus",
        "description": "第一个行为调用checkStatus"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "as",
        "description": "必须有as绑定"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "$item.status",
        "description": "condition中引用$item.status"
