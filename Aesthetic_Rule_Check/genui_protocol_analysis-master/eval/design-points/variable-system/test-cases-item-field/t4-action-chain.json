    "complexity": "complex",
    "task": "生成一个Extended.Button，label为'高级操作'，点击时：1.validate(as='vResult') 2.若$vResult==0且$__DataModel.user.canEdit为true则调用submitData",
    "expected": {
      "component": "Extended.Button",
      "required_fields": [
        "component",
        "label",
        "onClick"
