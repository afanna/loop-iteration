    "strategy_rules": {
      "listeners-handler": [
        {
          "type": "has_field",
          "field": "onClick",
          "description": "策略B：onClick直接作为组件属性"
        },
        {
          "type": "not_contains",
          "field": "$output",
          "value": "\"listeners\"",
          "description": "策略B不应有listeners字段"
        }
      ],
      "direct-action": [
        {
          "type": "has_field",
          "field": "onClick",
          "description": "策略B：onClick直接作为组件属性"
        },
        {
          "type": "not_contains",
          "field": "$output",
          "value": "\"listeners\"",
          "description": "策略B不应有listeners字段"
        }
      ]
    },
    "scope_conflict_type": "none",
    "hints": [
      "点击事件是onClick",
      "showToast用于显示提示消息"
    ]
