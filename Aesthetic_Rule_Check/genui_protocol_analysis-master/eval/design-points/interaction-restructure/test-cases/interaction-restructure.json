      {
        "type": "has_field",
        "field": "component",
        "description": "必须有component字段"
      },
      {
        "type": "has_field",
        "field": "label",
        "description": "必须有label字段"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "showToast",
        "description": "必须包含showToast行为"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "hello",
        "description": "消息内容为hello"
