[
  {
    "id": "CG001",
    "name": "线性渐变-基础双色",
    "category": "color-gradient-property",
    "complexity": "simple",
    "task": "生成一个 Extended.Button 组件，label 为“立即购买”，styles 中使用线性渐变颜色，从红色到橙色，两段 stop 分别是 0 和 1，不重复。",
    "expected": { "component": "Extended.Button", "required_fields": ["component", "label", "styles"], "patterns": [] },
    "validation_rules": [],
    "shared_rules": [
      { "type": "contains", "field": "label", "value": "立即购买", "description": "label 正确" },
      { "type": "contains", "field": "$output", "value": "\"colors\":", "description": "包含 colors" },
      { "type": "contains", "field": "$output", "value": "\"repeating\":false", "description": "repeating 为 false" }
    ],
    "strategy_rules": {
      "unified-gradient": [
        { "type": "contains", "field": "styles", "value": "\"colorGradient\":", "description": "使用 colorGradient 统一入口" },
        { "type": "contains", "field": "styles", "value": "\"type\":\"linearGradient\"", "description": "type 为 linearGradient" }
      ],
      "separate-gradients": [
        { "type": "contains", "field": "styles", "value": "\"linearGradient\":", "description": "使用 linearGradient 根字段" },
        { "type": "not_contains", "field": "styles", "value": "\"colorGradient\":", "description": "不应包含 colorGradient 包装对象" }
      ],
      "keyed-gradient": [
        { "type": "contains", "field": "styles", "value": "\"colorGradient\":", "description": "使用 colorGradient 单入口" },
        { "type": "contains", "field": "styles", "value": "\"linearGradient\":", "description": "在 colorGradient 下使用 linearGradient 单键对象" },
        { "type": "not_contains", "field": "styles", "value": "\"type\":", "description": "不应再使用 type 字段" }
      ]
    },
    "scope_conflict_type": "none",
    "is_edge": false
  },
