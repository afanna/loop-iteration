  {
    "id": "DM001",
    "name": "读取-单一字段",
    "category": "var-ref-syntax",
    "complexity": "simple",
    "task": "生成一个Text组件，显示数据模型中的用户名，用户名路径为 user.name",
    "expected": {
      "component": "Text",
      "required_fields": [
        "component",
        "content"
      ],
      "patterns": []
    },
    "validation_rules": [],
    "shared_rules": [
      {
        "type": "has_field",
        "field": "content",
        "description": "必须有content字段"
      }
    ],
    "strategy_rules": {
      "dot-path": [
        {
          "type": "contains",
          "field": "content",
          "value": "$__DataModel.user.name",
          "description": "使用$__DataModel.user.name点号路径"
        }
      ],
      "json-pointer": [
        {
          "type": "contains",
          "field": "content",
          "value": "path",
          "description": "使用path字段"
        },
        {
          "type": "contains",
          "field": "content",
          "value": "/user/name",
          "description": "路径为/user/name"
        }
      ]
    },
    "scope_conflict_type": "none",
    "is_edge": false
  },
