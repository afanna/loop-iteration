[
  {
    "id": "BA01",
    "name": "简单表单提交",
    "category": "variable-scope",
    "complexity": "simple",
    "task": "生成一个Button组件，id为'submitBtn'，label为'提交'，点击后提交表单，事件名为'submitForm'",
    "expected": {
      "component": "Button",
      "required_fields": [
        "component",
        "label"
      ],
      "patterns": []
    },
    "shared_rules": [
      {
        "type": "has_field",
        "field": "component",
        "description": "必须有component字段"
      },
      {
        "type": "has_field",
        "field": "label",
        "description": "必须有label字段"
      }
    ],
    "strategy_rules": {
      "button-action": [
        {
          "type": "has_field",
          "field": "action",
          "description": "方案A：表单提交使用action属性"
        },
        {
          "type": "contains",
          "field": "action",
          "value": "event",
          "description": "action中必须包含event字段"
        },
        {
          "type": "contains",
          "field": "action",
          "value": "submitForm",
          "description": "event.name必须是submitForm"
        },
        {
          "type": "not_contains",
          "field": "$output",
          "value": "onClick",
          "description": "有action时不应有onClick事件属性（互斥）"
        }
      ],
      "listeners-sendtollm": [
        {
          "type": "has_field",
          "field": "onClick",
          "description": "方案B：使用onClick事件属性 + sendToLLM"
        },
        {
          "type": "contains",
          "field": "onClick",
          "value": "onClick",
          "description": "必须包含onClick事件"
        },
        {
          "type": "contains",
          "field": "onClick",
          "value": "sendToLLM",
          "description": "必须使用sendToLLM提交"
        },
        {
          "type": "contains",
          "field": "onClick",
          "value": "submitForm",
          "description": "必须包含事件名submitForm"
        },
        {
          "type": "not_contains",
          "field": "$output",
          "value": "action",
          "description": "方案B不使用action属性"
        }
      ]
    },
    "scope_conflict_type": "none",
    "hints": [
      "提交表单是Button的表单提交场景"
    ]
  },
