  {
    "id": "BA01",
    "name": "简单表单提交-action",
    "category": "variable-scope",
    "complexity": "simple",
    "task": "生成一个Button组件，id为'submitBtn'，label为'提交'，点击后提交表单（事件名为'submitForm'）",
    "expected": {
      "component": "Button",
      "required_fields": [
        "component",
        "label",
        "action"
      ],
      "patterns": []
    },
    "shared_rules": [
      {
        "type": "has_field",
        "field": "component",
        "description": "必须有component字段"
      },
      {
        "type": "has_field",
        "field": "label",
        "description": "必须有label字段"
      },
      {
        "type": "has_field",
        "field": "action",
        "description": "必须有action字段（表单提交用action）"
      }
    ],
    "strategy_rules": {
      "button-action": [
        {
          "type": "contains",
          "field": "action",
          "value": "event",
          "description": "action中必须包含event字段"
        },
        {
          "type": "contains",
          "field": "action",
          "value": "submitForm",
          "description": "event.name必须是submitForm"
        },
        {
          "type": "not_contains",
          "field": "",
          "value": "onClick",
          "description": "纯表单提交不应使用onClick事件属性"
        }
      ]
    },
    "scope_conflict_type": "none",
    "hints": [
      "Button的表单提交使用action属性，格式为{event: {name: string, context?: object}}"
    ]
  },
