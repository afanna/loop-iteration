  {
    "id": "TI04",
    "name": "${}中算术表达式",
    "category": "template-interpolation",
    "complexity": "medium",
    "task": "生成一个Text组件，显示'合计：价格 × 数量 = 总价元'，其中$price和$quantity相乘的结果作为总价。用模板字符串${}实现。",
    "expected": {
      "component": "Text",
      "required_fields": ["component", "content"],
      "patterns": [
        {"field": "content", "must_contain": "`"},
        {"field": "content", "must_contain": "$price"},
        {"field": "content", "must_contain": "$quantity"}
      ]
    },
    "shared_rules": [
      {"type": "has_field", "description": "必须有component字段", "field": "component"},
      {"type": "has_field", "description": "必须有content字段", "field": "content"},
      {"type": "contains", "description": "expression必须用{{ }}包裹", "field": "content", "value": "{{"},
      {"type": "contains", "description": "必须使用模板字符串", "field": "content", "value": "`"},
      {"type": "contains", "description": "必须包含${}", "field": "content", "value": "${"},
      {"type": "matches_regex", "description": "${}内必须含算术运算*", "field": "content", "value": "\\$\\{[^}]*\\*[^}]*\\}"}
    ],
    "strategy_rules": {
      "template-text": [
        {"type": "contains", "description": "${}内可含$price", "field": "content", "value": "$price"}
      ],
      "explicit-only": [
        {"type": "contains", "description": "${}内必须含$price*$quantity", "field": "content", "value": "$price"}
      ]
    },
    "scope_conflict_type": "none",
    "hints": ["算术表达式必须放在${}内部", "动态值用{{ }}包裹"]
  },
