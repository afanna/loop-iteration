[
  {
    "id": "TI01",
    "name": "模板中简单$var插值",
    "category": "template-interpolation",
    "complexity": "simple",
    "task": "生成一个Text组件，内容为'你好，用户名！'，其中用户名是$name变量。用模板字符串（反引号）实现。",
    "expected": {
      "component": "Text",
      "required_fields": ["component", "content"],
      "patterns": [
        {"field": "content", "must_contain": "`"},
        {"field": "content", "must_contain": "$name"}
      ]
    },
    "shared_rules": [
      {"type": "has_field", "description": "必须有component字段", "field": "component"},
      {"type": "has_field", "description": "必须有content字段", "field": "content"},
      {"type": "contains", "description": "expression必须用{{ }}包裹", "field": "content", "value": "{{"},
      {"type": "contains", "description": "必须使用模板字符串", "field": "content", "value": "`"}
    ],
    "strategy_rules": {
      "template-text": [
        {"type": "contains", "description": "$name直接嵌入模板文本即可", "field": "content", "value": "$name"}
      ],
      "explicit-only": [
        {"type": "contains", "description": "必须用${}包裹变量引用", "field": "content", "value": "${"},
        {"type": "contains", "description": "变量$name在${}内部", "field": "content", "value": "$name"}
      ]
    },
    "scope_conflict_type": "none",
    "hints": ["动态值用{{ }}包裹", "用反引号模板字符串"]
  },
  {
    "id": "TI02",
    "name": "${}包裹简单变量",
    "category": "template-interpolation",
    "complexity": "simple",
    "task": "生成一个Text组件，内容为'欢迎，用户名！'，其中用户名是$userName变量。要求用${}语法包裹变量。",
    "expected": {
      "component": "Text",
      "required_fields": ["component", "content"],
      "patterns": [
        {"field": "content", "must_contain": "`"},
        {"field": "content", "must_contain": "$userName"},
        {"field": "content", "must_contain": "${"}
      ]
    },
    "shared_rules": [
      {"type": "has_field", "description": "必须有component字段", "field": "component"},
      {"type": "has_field", "description": "必须有content字段", "field": "content"},
      {"type": "contains", "description": "expression必须用{{ }}包裹", "field": "content", "value": "{{"},
      {"type": "contains", "description": "必须使用模板字符串", "field": "content", "value": "`"},
      {"type": "contains", "description": "必须包含$userName", "field": "content", "value": "$userName"}
    ],
    "strategy_rules": {
      "template-text": [
        {"type": "matches_regex", "description": "${}包裹$userName或直接用$userName均可", "field": "content", "value": "\\$\\{|\\$userName"}
      ],
      "explicit-only": [
        {"type": "contains", "description": "必须用${}包裹", "field": "content", "value": "${"},
        {"type": "matches_regex", "description": "${}内必须包含$userName", "field": "content", "value": "\\$\\{[^}]*\\$userName"}
      ]
    },
    "scope_conflict_type": "none",
    "hints": ["动态值用{{ }}包裹", "用${}语法明确插值"]
  },
