    "category": "template-interpolation",
    "complexity": "complex",
    "task": "生成一个Column组件，内含两个Text子组件：第一个显示'店铺名 - 营业中'，店铺名是$shopName；第二个显示'今日订单：N单'，N是$orders数组长度。每个子组件都用模板字符串。",
    "expected": {
      "component": "Column",
      "required_fields": ["component", "children"],
      "patterns": [
        {"field": "children", "must_contain": "$shopName"},
        {"field": "children", "must_contain": "$orders"}
      ]
    },
    "shared_rules": [
      {"type": "has_field", "description": "必须有component字段", "field": "component"},
      {"type": "has_field", "description": "Column必须有children字段", "field": "children"},
      {"type": "contains", "description": "children必须包含$shopName", "field": "children", "value": "$shopName"},
      {"type": "contains", "description": "children必须包含$orders", "field": "children", "value": "$orders"},
      {"type": "contains", "description": "必须使用模板字符串", "field": "children", "value": "`"}
    ],
    "strategy_rules": {
      "template-text": [
        {"type": "contains", "description": "子组件模板中$shopName可直接嵌入", "field": "children", "value": "$shopName"},
        {"type": "matches_regex", "description": "size()应在${}内", "field": "children", "value": "\\$\\{[^}]*size\\("}
      ],
      "explicit-only": [
        {"type": "contains", "description": "子组件中所有变量必须用${}包裹", "field": "children", "value": "${"}
      ]
    },
    "scope_conflict_type": "none",
    "is_edge": true,
    "hints": ["Column包含children数组", "子组件用模板字符串", "动态值用{{ }}包裹"]
  }
]
