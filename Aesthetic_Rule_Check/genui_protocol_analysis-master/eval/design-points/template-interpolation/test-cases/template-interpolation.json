    "category": "template-interpolation",
    "complexity": "medium",
    "task": "生成一个Text组件，显示'用户名: N条消息'，其中用户名是$userName变量，N是$count变量。要求用户名用$var直接嵌入，消息数用${}包裹。",
    "expected": {
      "component": "Text",
      "required_fields": ["component", "content"],
      "patterns": [
        {"field": "content", "must_contain": "`"},
        {"field": "content", "must_contain": "$userName"},
        {"field": "content", "must_contain": "$count"}
      ]
    },
    "shared_rules": [
      {"type": "has_field", "description": "必须有component字段", "field": "component"},
      {"type": "has_field", "description": "必须有content字段", "field": "content"},
      {"type": "contains", "description": "expression必须用{{ }}包裹", "field": "content", "value": "{{"},
      {"type": "contains", "description": "必须使用模板字符串", "field": "content", "value": "`"},
      {"type": "contains", "description": "必须包含$userName", "field": "content", "value": "$userName"},
      {"type": "contains", "description": "必须包含$count", "field": "content", "value": "$count"}
    ],
    "strategy_rules": {
      "template-text": [
        {"type": "matches_regex", "description": "模板中可含bare $userName和${$count}", "field": "content", "value": "`[^`]*\\$userName[^`]*\\$\\{[^}]*\\$count"}
      ],
      "explicit-only": [
        {"type": "contains", "description": "必须用${}包裹$userName", "field": "content", "value": "${"},
        {"type": "not_contains", "description": "模板文本中不应有裸露$userName（不在${}内）", "field": "content", "value": "${$userName}"}
      ]
    },
    "scope_conflict_type": "none",
    "hints": ["用户名用$var形式", "消息数用${}形式", "动态值用{{ }}包裹"]
  },
