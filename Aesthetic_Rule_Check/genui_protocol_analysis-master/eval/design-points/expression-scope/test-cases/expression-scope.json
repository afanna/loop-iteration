[
  {
    "id": "ES01",
    "name": "扩展组件-文本属性用表达式",
    "category": "expression-wrapping",
    "complexity": "simple",
    "task": "生成一个Extended.Text组件，id为greeting，显示用户名$user.name",
    "expected": {
      "component": "Extended.Text",
      "required_fields": [
        "component",
        "id",
        "text"
      ],
      "patterns": []
    },
    "validation_rules": [],
    "shared_rules": [
      {
        "type": "has_field",
        "field": "component",
        "description": "必须有component字段"
      },
      {
        "type": "has_field",
        "field": "id",
        "description": "必须有id字段"
      },
      {
        "type": "has_field",
        "field": "text",
        "description": "必须有text字段"
      }
    ],
    "strategy_rules": {
      "inline": [
        {
          "type": "matches_regex",
          "field": "text",
          "value": "^\\{\\{.*\\}\\}$",
          "description": "text使用{{}}包裹"
        },
        {
          "type": "contains",
          "field": "text",
          "value": "$user.name",
          "description": "引用$user.name"
        }
      ],
      "wrapped": [
        {
          "type": "matches_regex",
          "field": "text",
          "value": "^\\{\\{.*\\}\\}$",
          "description": "text使用{{}}包裹"
        },
        {
          "type": "contains",
          "field": "text",
          "value": "$user.name",
          "description": "引用$user.name"
        }
      ]
    },
    "scope_conflict_type": "none",
    "hints": [
      "Extended组件的text属性可以使用表达式"
    ]
  },
