    "task": "生成一个Text组件，显示价格信息，格式为'价格: '后面接$price变量的值",
    "expected": {
      "component": "Text",
      "required_fields": ["component", "content"],
      "patterns": []
    },
    "shared_rules": [
      {"type": "has_field", "field": "component", "description": "必须有component字段"},
      {"type": "has_field", "field": "content", "description": "必须有content字段"}
    ],
    "strategy_rules": {
      "asymmetric": [
        {"type": "contains", "field": "content", "value": "$price", "description": "引用$price变量"},
        {"type": "contains", "field": "content", "value": "价格", "description": "包含'价格'文本"}
