  {
    "id": "TC06",
    "name": "数字变量+单位后缀(数量)",
    "category": "type-conversion",
    "complexity": "medium",
    "task": "生成一个Text组件，显示$count变量的值后面跟'件'字，如'5件'",
    "expected": {
      "component": "Text",
      "required_fields": ["component", "content"],
      "patterns": []
    },
    "shared_rules": [
      {"type": "has_field", "field": "component", "description": "必须有component字段"},
      {"type": "has_field", "field": "content", "description": "必须有content字段"}
    ],
    "strategy_rules": {
      "asymmetric": [
        {"type": "contains", "field": "content", "value": "$count", "description": "引用$count变量"},
        {"type": "contains", "field": "content", "value": "件", "description": "包含'件'字"},
        {"type": "not_contains", "field": "content", "value": "{{ $count + '", "description": "不对称规则下禁止$number直接接+'string'模式（$var必须在+前面有字符串前缀）"}
