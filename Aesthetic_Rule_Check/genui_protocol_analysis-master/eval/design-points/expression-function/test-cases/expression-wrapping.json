[
  {
    "id": "EW01",
    "name": "简单变量绑定",
    "category": "expression-wrapping",
    "complexity": "simple",
    "task": "生成一个Text组件，显示用户名$username",
    "expected": {
      "component": "Text",
      "required_fields": [
        "component",
        "content"
      ],
      "patterns": []
    },
    "validation_rules": [],
    "shared_rules": [
      {
        "type": "has_field",
        "field": "component",
        "description": "必须有component字段"
      },
      {
        "type": "has_field",
        "field": "content",
        "description": "必须有content字段"
      }
    ],
    "strategy_rules": {
      "inline": [
        {
          "type": "matches_regex",
          "field": "content",
          "value": "^\\{\\{.*\\}\\}$",
          "description": "content使用{{}}包裹"
        },
        {
          "type": "contains",
          "field": "content",
          "value": "$username",
          "description": "引用$username"
        }
      ],
      "wrapped": [
        {
          "type": "field_is_expr",
          "field": "content",
          "description": "content使用expr格式"
        },
        {
          "type": "contains",
          "field": "content.expr",
          "value": "$username",
          "description": "引用$username"
        }
      ]
    },
    "scope_conflict_type": "none",
    "hints": [
      "动态值用对应语法包裹"
    ]
  },
