[
  {
    "id": "BF01",
    "name": "简单变量插值",
    "category": "expression-wrapping",
    "complexity": "simple",
    "task": "生成一个Text组件，显示用户名$username，文本格式为'Hello'后面跟用户名",
    "expected": {
      "component": "Text",
      "required_fields": ["component", "content"],
      "patterns": [
        { "field": "content", "must_contain": "{{" },
        { "field": "content", "must_contain": "$username" }
      ]
    },
    "shared_rules": [
      { "type": "has_field", "description": "必须有component字段", "field": "component" },
      { "type": "has_field", "description": "必须有content字段", "field": "content" },
      { "type": "contains", "description": "content必须包含变量$username", "field": "content", "value": "$username" }
    ],
    "strategy_rules": {
      "format": [
        { "type": "contains", "description": "必须使用format函数", "field": "content", "value": "format(" },
        { "type": "contains", "description": "format使用槽位占位符", "field": "content", "value": "{}" },
        { "type": "not_contains", "description": "不能使用模板字符串反引号", "field": "content", "value": "`" }
      ],
      "template-literal": [
        { "type": "contains", "description": "必须使用模板字符串（反引号）", "field": "content", "value": "`" },
        { "type": "contains", "description": "模板字符串内使用${}插值", "field": "content", "value": "${" },
        { "type": "not_contains", "description": "不能使用format函数", "field": "content", "value": "format(" }
      ],
      "coexist": [
        { "type": "matches_regex", "description": "使用format函数或模板字符串之一", "field": "content", "value": "(format\\(|`)" }
      ]
    },
    "scope_conflict_type": "none",
    "hints": ["动态值用{{ }}包裹", "Text组件的文本用content字段"]
  },
