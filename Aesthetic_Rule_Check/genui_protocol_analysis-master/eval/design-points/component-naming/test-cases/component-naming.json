[
  {
    "id": "CN01",
    "name": "简单文本显示",
    "category": "component-naming",
    "complexity": "simple",
    "task": "生成一个文本组件，id为'greeting'，显示动态内容'Hello, '拼接$__DataModel.username",
    "expected": {
      "required_fields": [
        "id",
        "component"
      ],
      "patterns": []
    },
    "shared_rules": [
      {
        "type": "has_field",
        "field": "id",
        "description": "必须有id字段"
      },
      {
        "type": "has_field",
        "field": "component",
        "description": "必须有component字段"
      },
      {
        "type": "contains",
        "field": "component",
        "value": "Text",
        "description": "component包含Text"
      }
    ],
    "strategy_rules": {
      "extended-prefix": [
        {
          "type": "contains",
          "field": "component",
          "value": "Extended.Text",
          "description": "使用Extended.Text命名"
        }
      ],
      "unified-name": [
        {
          "type": "matches_regex",
          "field": "component",
          "value": "^Text$",
          "description": "使用纯Text命名（无前缀）"
        }
      ],
      "short-prefix": [
        {
          "type": "contains",
          "field": "component",
          "value": "HText",
          "description": "使用HText命名"
        }
      ]
    },
    "scope_conflict_type": "none"
  },
