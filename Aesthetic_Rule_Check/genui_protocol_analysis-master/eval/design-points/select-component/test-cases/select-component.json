[
  {
    "id": "SC001",
    "name": "基本静态下拉选择",
    "category": "select-component",
    "complexity": "simple",
    "task": "生成一个Extended.Select下拉选择组件，选项为'北京'和'上海'，默认选中'北京'。",
    "expected": {
      "component": "Extended.Select",
      "required_fields": [
        "component",
        "id",
        "options"
      ],
      "patterns": [
        {
          "field": "options",
          "must_be_type": "array"
        }
      ]
    },
    "validation_rules": [],
    "shared_rules": [
      {
        "type": "has_field",
        "description": "必须包含options字段",
        "field": "options"
      },
      {
        "type": "has_field",
        "description": "必须包含id字段",
        "field": "id"
      }
    ],
    "strategy_rules": {
      "label-value": [
        {
          "type": "contains",
          "field": "options[0].label",
          "value": "北京",
          "description": "选项label为北京"
        },
        {
          "type": "contains",
          "field": "options[0].value",
          "value": "beijing",
          "description": "选项value为beijing"
        }
      ],
      "value-flat": [
        {
          "type": "contains",
          "field": "options[0].value",
          "value": "北京",
          "description": "选项value为北京"
        }
      ],
      "index-based": [
        {
          "type": "contains",
          "field": "options[0].value",
          "value": "北京",
          "description": "选项value为北京"
        },
        {
          "type": "has_field",
          "field": "selected",
          "description": "必须包含selected索引字段"
        }
      ]
    },
    "scope_conflict_type": "none",
    "hints": [
      "Extended.Select使用options数组定义下拉选项"
    ]
  },
