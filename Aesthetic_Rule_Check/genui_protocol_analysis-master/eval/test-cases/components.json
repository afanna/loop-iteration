  {
    "id": "C003",
    "name": "主题+样式覆盖",
    "category": "component",
    "complexity": "medium",
    "task": "生成一个Text组件，内容'品牌标题'，使用heading1主题，但字体颜色覆盖为#007AFF",
    "expected": {
      "component": "Text",
      "required_fields": ["component", "content", "theme", "styles"],
      "patterns": [
        {"field": "content", "must_contain": "品牌标题"},
        {"field": "theme", "must_contain": "heading1"},
        {"field": "styles.fontColor", "must_contain": "#007AFF"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "description": "必须有theme字段", "field": "theme"},
      {"type": "has_field", "description": "必须有styles字段", "field": "styles"},
      {"type": "has_field", "description": "styles中必须覆盖fontColor", "field": "styles.fontColor"}
    ],
    "hints": ["theme和styles可以共存", "styles会覆盖theme中对应的属性"]
  },
