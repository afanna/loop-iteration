  {
    "id": "FP0104",
    "name": "Extended.Button enabled绑定表达式",
    "category": "component",
    "complexity": "medium",
    "task": "生成一个Extended.Button组件，id为confirm-btn，label为\"确认\"，enabled属性绑定表达式判断$formValid是否为true，使用buttonPrimary主题",
    "expected": {
      "component": "Extended.Button",
      "required_fields": ["id", "component", "label", "enabled"],
      "patterns": [
        {"field": "label", "must_contain": "确认"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "component", "description": "必须有component字段"},
      {"type": "contains", "field": "component", "value": "Extended.Button", "description": "必须使用Extended.Button组件"},
      {"type": "has_field", "field": "enabled", "description": "必须有enabled字段"},
      {"type": "contains", "field": "enabled", "value": "$formValid", "description": "enabled应使用表达式引用$formValid"},
      {"type": "contains", "field": "$output", "value": "buttonPrimary", "description": "必须使用buttonPrimary主题"}
    ],
    "hints": ["enabled是布尔属性，支持动态表达式", "表达式使用双花括号{{}}包裹"]
  },
  {
