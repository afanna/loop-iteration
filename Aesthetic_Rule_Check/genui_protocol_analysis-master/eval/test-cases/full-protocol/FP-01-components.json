        {"field": "theme", "must_contain": "heading1"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "component", "description": "必须有component字段"},
      {"type": "contains", "field": "component", "value": "Extended.Text", "description": "必须使用Extended.Text组件"},
      {"type": "has_field", "field": "theme", "description": "必须有theme字段"},
      {"type": "contains", "field": "theme", "value": "heading1", "description": "theme必须为heading1"}
    ],
    "hints": ["主题通过theme字段设置", "文本主题有heading1、heading2、body、caption等"]
  },
  {
