[
  {
    "id": "FP0101",
    "name": "Extended.Text 静态文本",
    "category": "component",
    "complexity": "simple",
    "task": "生成一个Extended.Text组件，id为welcome-text，content为\"欢迎使用鸿蒙\"",
    "expected": {
      "component": "Extended.Text",
      "required_fields": ["id", "component", "content"],
      "patterns": [
        {"field": "content", "must_contain": "欢迎使用鸿蒙"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "component", "description": "必须有component字段"},
      {"type": "contains", "field": "component", "value": "Extended.Text", "description": "必须使用Extended.Text组件"},
      {"type": "has_field", "field": "content", "description": "必须有content字段"}
    ],
    "hints": ["Extended.Text组件用content字段表示文本内容", "扩展组件使用Extended.前缀命名"]
  },
  {
    "id": "FP0102",
    "name": "Extended.Text 使用主题",
    "category": "component",
    "complexity": "simple",
    "task": "生成一个Extended.Text组件，id为page-title，content为\"设置中心\"，使用heading1主题",
    "expected": {
      "component": "Extended.Text",
      "required_fields": ["id", "component", "content", "theme"],
      "patterns": [
