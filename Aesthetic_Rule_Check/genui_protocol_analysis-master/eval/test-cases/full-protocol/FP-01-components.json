  {
    "id": "FP0106",
    "name": "Extended.TextInput 带maxLength限制",
    "category": "component",
    "complexity": "medium",
    "task": "生成一个Extended.TextInput组件，id为phone-input，text为空字符串，placeholder为\"请输入手机号\"，maxLength为11，type为number",
    "expected": {
      "component": "Extended.TextInput",
      "required_fields": ["id", "component", "text", "placeholder", "maxLength"],
      "patterns": [
        {"field": "placeholder", "must_contain": "手机号"},
        {"field": "maxLength", "must_be_type": "number"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "component", "description": "必须有component字段"},
      {"type": "contains", "field": "component", "value": "Extended.TextInput", "description": "必须使用Extended.TextInput组件"},
      {"type": "has_field", "field": "maxLength", "description": "必须有maxLength字段"},
      {"type": "matches_regex", "field": "maxLength", "value": "^\\d+$", "description": "maxLength必须是数字"}
    ],
    "hints": ["maxLength是数字类型，限制最大输入字符数", "type字段可设置输入类型如number"]
  },
