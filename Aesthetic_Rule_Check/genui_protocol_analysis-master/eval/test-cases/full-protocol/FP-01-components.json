  {
    "id": "FP0109",
    "name": "Extended.Select 下拉选择",
    "category": "component",
    "complexity": "medium",
    "task": "生成一个Extended.Select组件，id为city-select，options包含三个选项(value分别为\"北京\"、\"上海\"、\"广州\")，selected为0，value为\"北京\"",
    "expected": {
      "component": "Extended.Select",
      "required_fields": ["id", "component", "options", "selected", "value"],
      "patterns": [
        {"field": "options", "must_be_type": "array"},
        {"field": "selected", "must_be_type": "number"},
        {"field": "value", "must_contain": "北京"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "component", "description": "必须有component字段"},
      {"type": "contains", "field": "component", "value": "Extended.Select", "description": "必须使用Extended.Select组件"},
      {"type": "has_field", "field": "options", "description": "必须有options字段"},
      {"type": "has_field", "field": "selected", "description": "必须有selected字段"},
      {"type": "has_field", "field": "value", "description": "必须有value字段"}
    ],
    "hints": ["options是对象数组，每个对象有value属性", "selected是数字索引，value是下拉按钮的文本"]
  },
  {
    "id": "FP0110",
    "name": "Extended.Radio 单选组",
    "category": "component",
    "complexity": "medium",
    "task": "生成两个Extended.Radio组件。第一个id为radio-male，value为\"male\"，group为\"gender\"，checked为true。第二个id为radio-female，value为\"female\"，group为\"gender\"，checked为false",
    "expected": {
      "required_fields": ["id", "component"],
      "patterns": [
        {"field": "component", "must_contain": "Extended.Radio"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "component", "description": "必须有component字段"},
      {"type": "contains", "field": "$output", "value": "Extended.Radio", "description": "必须使用Extended.Radio组件"},
      {"type": "contains", "field": "$output", "value": "gender", "description": "必须包含group字段值为gender"},
      {"type": "contains", "field": "$output", "value": "male", "description": "必须包含value为male的选项"}
    ],
    "hints": ["Extended.Radio用value表示选项值，group表示所属组名", "相同group的Radio只能选中一个", "checked布尔值表示选中状态"]
  },
  {
    "id": "FP0111",
    "name": "Extended.Checkbox 多选框",
    "category": "component",
    "complexity": "medium",
    "task": "生成两个Extended.Checkbox组件。第一个id为cb-agree，value为\"agree\"，group为\"terms\"，select为true。第二个id为cb-marketing，value为\"marketing\"，group为\"terms\"，select为false",
    "expected": {
      "required_fields": ["id", "component"],
      "patterns": [
        {"field": "component", "must_contain": "Extended.Checkbox"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "component", "description": "必须有component字段"},
      {"type": "contains", "field": "$output", "value": "Extended.Checkbox", "description": "必须使用Extended.Checkbox组件"},
      {"type": "contains", "field": "$output", "value": "value", "description": "必须包含value字段作为语义化标识"},
      {"type": "contains", "field": "$output", "value": "terms", "description": "必须包含group字段值为terms"},
      {"type": "contains", "field": "$output", "value": "select", "description": "必须包含select字段"}
    ],
    "hints": ["Extended.Checkbox用value作为语义化标识（不绘制显示），label为展示文本", "Extended.Checkbox用group指定所属群组", "select布尔值表示选中状态"]
  },
