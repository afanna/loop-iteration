  {
    "id": "FP0303",
    "name": "Padding object form",
    "category": "style",
    "complexity": "medium",
    "task": "生成一个Extended.Text组件，显示文字'用户信息'，设置内边距padding为对象形式：上8、下12、左16、右16",
    "expected": {
      "component": "Extended.Text",
      "required_fields": ["id", "component", "content", "styles"],
      "patterns": [
        {"field": "content", "must_contain": "用户信息"},
        {"field": "styles.padding", "must_be_type": "object"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "styles", "description": "必须有styles对象"},
      {"type": "has_field", "field": "styles.padding", "description": "styles中必须有padding"},
      {"type": "has_field", "field": "styles.padding.top", "description": "padding对象中必须有top"},
      {"type": "has_field", "field": "styles.padding.bottom", "description": "padding对象中必须有bottom"},
      {"type": "has_field", "field": "styles.padding.left", "description": "padding对象中必须有left"},
      {"type": "has_field", "field": "styles.padding.right", "description": "padding对象中必须有right"},
      {"type": "contains", "field": "styles.padding.top", "value": "8", "description": "padding.top应为8"},
      {"type": "contains", "field": "styles.padding.bottom", "value": "12", "description": "padding.bottom应为12"}
    ],
    "hints": ["padding可以设置为对象{top, right, bottom, left}", "四个属性都是可选的", "默认单位vp"]
  },
  {
    "id": "FP0304",
    "name": "Width/height with units",
    "category": "style",
    "complexity": "medium",
    "task": "生成一个Extended.Column组件，设置宽度width为100%（占满父容器），高度height为matchParent",
    "expected": {
      "component": "Extended.Column",
      "required_fields": ["id", "component", "styles"],
      "patterns": [
        {"field": "styles.width", "must_contain": "100%"},
        {"field": "styles.height", "must_contain": "matchParent"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "styles", "description": "必须有styles对象"},
      {"type": "has_field", "field": "styles.width", "description": "styles中必须有width"},
      {"type": "has_field", "field": "styles.height", "description": "styles中必须有height"},
      {"type": "contains", "field": "styles.width", "value": "100%", "description": "width应为100%"},
      {"type": "contains", "field": "styles.height", "value": "matchParent", "description": "height应为matchParent"}
    ],
    "hints": ["width/height支持数字（vp）、字符串（带单位如'100fp'、'100%'）或枚举值", "枚举值有matchParent、wrapContent、fixAtIdealSize"]
  },
  {
