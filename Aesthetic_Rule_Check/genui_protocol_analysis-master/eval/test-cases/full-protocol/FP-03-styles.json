[
  {
    "id": "FP0301",
    "name": "Text with fontSize and fontColor",
    "category": "style",
    "complexity": "simple",
    "task": "生成一个Extended.Text组件，显示文字'商品名称'，设置字体大小为14fp，字体颜色为#333333",
    "expected": {
      "component": "Extended.Text",
      "required_fields": ["id", "component", "content", "styles"],
      "patterns": [
        {"field": "content", "must_contain": "商品名称"},
        {"field": "styles.fontSize", "must_contain": "14"},
        {"field": "styles.fontColor", "must_contain": "#333333"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "styles", "description": "必须有styles对象"},
      {"type": "has_field", "field": "styles.fontSize", "description": "styles中必须有fontSize"},
      {"type": "has_field", "field": "styles.fontColor", "description": "styles中必须有fontColor"},
      {"type": "contains", "field": "styles.fontSize", "value": "14", "description": "fontSize应为14"},
      {"type": "contains", "field": "styles.fontColor", "value": "#333333", "description": "fontColor应为#333333"}
    ],
    "hints": ["样式属性放在styles对象中", "fontSize为数字类型，单位fp", "fontColor为16进制字符串"]
  },
  {
