    "category": "style",
    "complexity": "simple",
    "task": "生成一个Extended.Row组件，包含title和action两个子组件，设置主轴对齐方式justifyContent为spaceBetween（两端对齐）",
    "expected": {
      "component": "Extended.Row",
      "required_fields": ["id", "component", "children", "styles"],
      "patterns": [
        {"field": "children", "must_be_type": "array"},
