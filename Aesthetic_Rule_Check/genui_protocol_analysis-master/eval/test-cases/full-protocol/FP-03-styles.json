      {"type": "has_field", "field": "styles.justifyContent", "description": "styles中必须有justifyContent"},
      {"type": "contains", "field": "styles.justifyContent", "value": "spaceBetween", "description": "justifyContent应为spaceBetween"}
    ],
    "hints": ["Extended.Row的justifyContent控制水平方向对齐", "枚举值有start、center、end、spaceBetween、spaceAround、spaceEvenly"]
