      "required_fields": ["id", "component", "content", "styles"],
      "patterns": [
        {"field": "content", "must_contain": "标签"},
        {"field": "styles.borderWidth", "must_contain": "1"},
        {"field": "styles.borderRadius", "must_contain": "8"},
        {"field": "styles.borderColor", "must_contain": "#CCCCCC"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "styles", "description": "必须有styles对象"},
      {"type": "has_field", "field": "styles.borderWidth", "description": "styles中必须有borderWidth"},
      {"type": "has_field", "field": "styles.borderRadius", "description": "styles中必须有borderRadius"},
      {"type": "has_field", "field": "styles.borderColor", "description": "styles中必须有borderColor"},
      {"type": "contains", "field": "styles.borderWidth", "value": "1", "description": "borderWidth应为1"},
      {"type": "contains", "field": "styles.borderRadius", "value": "8", "description": "borderRadius应为8"}
