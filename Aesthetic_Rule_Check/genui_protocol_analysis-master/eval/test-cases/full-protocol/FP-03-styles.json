  {
    "id": "FP0306",
    "name": "Visibility control",
    "category": "style",
    "complexity": "simple",
    "task": "生成一个Extended.Text组件，显示文字'隐藏提示'，设置可见性visibility为hidden（不可见但占位）",
    "expected": {
      "component": "Extended.Text",
      "required_fields": ["id", "component", "content", "styles"],
      "patterns": [
        {"field": "content", "must_contain": "隐藏提示"},
        {"field": "styles.visibility", "must_contain": "hidden"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "styles", "description": "必须有styles对象"},
      {"type": "has_field", "field": "styles.visibility", "description": "styles中必须有visibility"},
      {"type": "contains", "field": "styles.visibility", "value": "hidden", "description": "visibility应为hidden"}
    ],
    "hints": ["visibility有三个枚举值：visible（可见）、hidden（不可见但占位）、none（不可见也不占位）"]
  },
  {
    "id": "FP0307",
    "name": "Layout weight in Row child",
    "category": "style",
    "complexity": "medium",
    "task": "生成一个Extended.Row组件，包含子组件left和right。为left设置layoutWeight为2，为right设置layoutWeight为1，使左侧占2/3、右侧占1/3空间",
    "expected": {
      "component": "Extended.Row",
      "required_fields": ["id", "component", "children", "styles"],
      "patterns": [
        {"field": "children", "must_be_type": "array"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "children", "description": "必须有children字段"},
      {"type": "has_field", "field": "styles", "description": "必须有styles对象"}
    ],
    "hints": ["layoutWeight仅在父节点为Row或Column时生效", "layoutWeight设置布局权重，数值越大占比越大"]
  },
  {
    "id": "FP0308",
    "name": "Text maxLines and textOverflow",
    "category": "style",
    "complexity": "medium",
    "task": "生成一个Extended.Text组件，显示文字'这是一段很长的描述文本，需要在超长时自动截断显示省略号'，设置最大行数maxLines为2，文本溢出处理textOverflow为ellipsis（省略号）",
    "expected": {
      "component": "Extended.Text",
      "required_fields": ["id", "component", "content", "styles"],
      "patterns": [
        {"field": "styles.maxLines", "must_contain": "2"},
        {"field": "styles.textOverflow", "must_contain": "ellipsis"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "styles", "description": "必须有styles对象"},
      {"type": "has_field", "field": "styles.maxLines", "description": "styles中必须有maxLines"},
      {"type": "has_field", "field": "styles.textOverflow", "description": "styles中必须有textOverflow"},
      {"type": "contains", "field": "styles.maxLines", "value": "2", "description": "maxLines应为2"},
      {"type": "contains", "field": "styles.textOverflow", "value": "ellipsis", "description": "textOverflow应为ellipsis"}
    ],
    "hints": ["maxLines设置文本最大行数，数值类型", "textOverflow需配合maxLines使用，枚举值有none、clip、ellipsis、marquee"]
  },
  {
