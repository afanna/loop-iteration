    "category": "expression",
    "complexity": "complex",
    "task": "生成一个Extended.Text组件，内容为复杂表达式：$isVip为true时显示'VIP价格：'拼接$price * 0.8的结果，否则显示'普通价格：'拼接$price原价。使用三元运算符、算术运算和属性访问组合",
    "expected": {
      "component": "Extended.Text",
      "required_fields": [
        "id",
        "component",
        "content"
      ],
      "patterns": [
        {
          "field": "content",
          "must_contain": "{{"
        },
        {
          "field": "content",
          "must_contain": "$isVip"
        },
        {
          "field": "content",
          "must_contain": "?"
        },
        {
          "field": "content",
          "must_contain": "$price"
        }
      ]
    },
    "validation_rules": [
      {
        "type": "contains",
        "field": "content",
        "value": "{{",
        "description": "content必须使用{{}}表达式语法"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "$isVip",
        "description": "必须引用$isVip变量"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "?",
        "description": "必须使用三元运算符"
      },
      {
        "type": "contains",
        "field": "content",
        "value": ":",
        "description": "必须使用三元运算符else分支"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "$price",
        "description": "必须引用$price变量"
      }
    ],
    "hints": [
      "三元运算符 + 算术运算 + 属性访问的组合",
      "使用字符串拼接连接标签和计算结果"
    ]
  },
  {
