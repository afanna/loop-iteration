  {
    "id": "FP0403",
    "name": "Arithmetic expression",
    "category": "expression",
    "complexity": "medium",
    "task": "生成一个Extended.Text组件，内容为价格计算表达式：$price * $quantity，显示总价",
    "expected": {
      "component": "Extended.Text",
      "required_fields": [
        "id",
        "component",
        "content"
      ],
      "patterns": [
        {
          "field": "content",
          "must_contain": "{{"
        },
        {
          "field": "content",
          "must_contain": "$price"
        },
        {
          "field": "content",
          "must_contain": "*"
        },
        {
          "field": "content",
          "must_contain": "$quantity"
        }
      ]
    },
    "validation_rules": [
      {
        "type": "contains",
        "field": "content",
        "value": "{{",
        "description": "content必须使用{{}}表达式语法"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "$price",
        "description": "必须引用$price变量"
