  {
    "id": "FP0404",
    "name": "Comparison + ternary",
    "category": "expression",
    "complexity": "medium",
    "task": "生成一个Extended.Text组件，$age >= 18时显示'成年人'，否则显示'未成年'，使用三元运算符",
    "expected": {
      "component": "Extended.Text",
      "required_fields": [
        "id",
        "component",
        "content"
      ],
      "patterns": [
        {
          "field": "content",
          "must_contain": "{{"
        },
        {
          "field": "content",
          "must_contain": "?"
        },
        {
          "field": "content",
          "must_contain": ":"
        },
        {
          "field": "content",
          "must_contain": "$age"
        }
      ]
    },
    "validation_rules": [
      {
        "type": "contains",
        "field": "content",
        "value": "{{",
        "description": "content必须使用{{}}表达式语法"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "$age",
        "description": "必须引用$age变量"
      },
      {
        "type": "contains",
        "field": "content",
        "value": ">=",
        "description": "必须使用比较运算符>="
      },
      {
        "type": "contains",
        "field": "content",
        "value": "?",
        "description": "必须使用三元运算符?"
      },
      {
        "type": "contains",
        "field": "content",
        "value": ":",
        "description": "必须使用三元运算符:"
      }
    ],
    "hints": [
      "三元运算符格式：条件 ? 真值 : 假值",
      "比较运算符有>、>=、<、<=、==、!="
    ]
  },
  {
