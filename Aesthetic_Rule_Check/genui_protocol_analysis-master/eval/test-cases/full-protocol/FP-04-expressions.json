    "expected": {
      "component": "Extended.Button",
      "required_fields": [
        "id",
        "component",
        "label",
        "onClick"
      ],
      "patterns": [
        {
          "field": "label",
          "must_contain": "确认删除"
        },
        {
          "field": "onClick",
          "must_be_type": "array"
        }
      ]
    },
    "validation_rules": [
      {
        "type": "has_field",
        "field": "onClick",
        "description": "必须有onClick事件属性"
      },
      {
        "type": "has_field",
        "field": "onClick",
        "description": "必须有onClick事件"
      },
      {
        "type": "chain_format",
        "description": "onClick必须是行为数组格式"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "as",
        "description": "前置行为必须通过as绑定结果变量"
      },
      {
        "type": "contains",
        "field": "$output",
        "value": "condition",
        "description": "后续行为必须通过condition引用as绑定的变量"
      }
    ],
    "hints": [
      "通过as（如as:'confirmed'）绑定前置行为返回值",
      "后续行为用condition引用$confirmed == 0",
      "行为数组中的condition使用{{}}表达式"
    ]
  }
