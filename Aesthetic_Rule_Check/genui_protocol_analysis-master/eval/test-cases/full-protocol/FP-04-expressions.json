    "expected": {
      "component": "Extended.Text",
      "required_fields": [
        "id",
        "component",
        "content"
      ],
      "patterns": [
        {
          "field": "content",
          "must_contain": "{{"
        },
        {
          "field": "content",
          "must_contain": "$isAdmin"
        },
        {
          "field": "content",
          "must_contain": "&&"
        },
        {
          "field": "content",
          "must_contain": "$isActive"
        }
      ]
    },
    "validation_rules": [
      {
        "type": "contains",
        "field": "content",
        "value": "{{",
        "description": "content必须使用{{}}表达式语法"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "$isAdmin",
        "description": "必须引用$isAdmin变量"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "&&",
        "description": "必须使用逻辑与运算符&&"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "$isActive",
        "description": "必须引用$isActive变量"
