    "hints": [
      "逻辑运算符有&&（与）、||（或）、!（非）",
      "可以与三元运算符组合使用"
    ]
  },
  {
    "id": "FP0406",
    "name": "Nested ternary (multi-branch)",
    "category": "expression",
    "complexity": "complex",
    "task": "生成一个Extended.Text组件，根据$__widthBreakpoint断点显示不同布局标签：sm时显示'移动端'、md时显示'平板'、其他显示'桌面端'，使用嵌套三元运算符",
    "expected": {
      "component": "Extended.Text",
      "required_fields": [
        "id",
        "component",
        "content"
      ],
      "patterns": [
        {
          "field": "content",
          "must_contain": "{{"
        },
        {
          "field": "content",
          "must_contain": "$__widthBreakpoint"
        },
        {
          "field": "content",
          "must_contain": "sm"
        },
        {
          "field": "content",
          "must_contain": "md"
        }
      ]
    },
    "validation_rules": [
      {
        "type": "contains",
        "field": "content",
        "value": "{{",
        "description": "content必须使用{{}}表达式语法"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "$__widthBreakpoint",
        "description": "必须引用$__widthBreakpoint全局变量"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "sm",
        "description": "必须包含sm断点判断"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "md",
        "description": "必须包含md断点判断"
      }
    ],
    "hints": [
      "嵌套三元运算符格式：条件1 ? 值1 : 条件2 ? 值2 : 值3",
      "$__widthBreakpoint是全局响应式变量"
    ]
  },
