  {
    "id": "FP0213",
    "name": "多组件JSON数组",
    "category": "layout",
    "complexity": "complex",
    "task": "生成一个页面布局，包含4个组件：Extended.Column(id为page-root，children为[\"page-header\", \"page-body\"])，Extended.Text(id为page-header，content为\"页面标题\")，Extended.Row(id为page-body，children为[\"left-section\", \"right-section\"])，Extended.Text(id为left-section，content为\"左侧内容\")",
    "expected": {
      "required_fields": ["id", "component"],
      "patterns": [
        {"field": "component", "must_contain": "Extended.Column"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "component", "description": "必须有component字段"},
      {"type": "contains", "field": "$output", "value": "Extended.Column", "description": "必须包含Extended.Column根布局"},
      {"type": "contains", "field": "$output", "value": "Extended.Text", "description": "必须包含Extended.Text组件"},
      {"type": "contains", "field": "$output", "value": "Extended.Row", "description": "必须包含Extended.Row组件"},
      {"type": "contains", "field": "$output", "value": "页面标题", "description": "必须包含\"页面标题\"文本内容"},
      {"type": "contains", "field": "$output", "value": "左侧内容", "description": "必须包含\"左侧内容\"文本内容"}
    ],
    "hints": ["这是一个多组件组合场景，需要输出JSON数组", "components数组中每个组件有独立的id和component", "组件之间通过children和id相互引用"]
  },
