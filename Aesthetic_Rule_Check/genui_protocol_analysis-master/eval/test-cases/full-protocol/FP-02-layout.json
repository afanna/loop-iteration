  {
    "id": "FP0206",
    "name": "Extended.Tabs + Extended.TabContent 多组件",
    "category": "layout",
    "complexity": "complex",
    "task": "生成一个Tabs页面布局，包含一个Extended.Tabs组件(id为main-tabs，children为[\"tab-home\", \"tab-profile\"])和两个Extended.TabContent子组件(id为tab-home，title为\"首页\"，children为[\"home-content\"]；id为tab-profile，title为\"我的\"，children为[\"profile-content\"])",
    "expected": {
      "required_fields": ["id", "component"],
      "patterns": [
        {"field": "component", "must_contain": "Extended.Tabs"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "component", "description": "必须有component字段"},
      {"type": "contains", "field": "$output", "value": "Extended.Tabs", "description": "必须包含Extended.Tabs组件"},
      {"type": "contains", "field": "$output", "value": "Extended.TabContent", "description": "必须包含Extended.TabContent子组件"},
      {"type": "contains", "field": "$output", "value": "title", "description": "TabContent必须有title字段"},
      {"type": "contains", "field": "$output", "value": "首页", "description": "某个TabContent的title必须为首页"}
    ],
    "hints": ["Extended.Tabs是选项卡容器，children引用Extended.TabContent组件ID", "Extended.TabContent必须有title字段表示页签标题", "这是一个多组件输出，应生成JSON数组"]
  },
