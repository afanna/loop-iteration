  {
    "id": "FP0208",
    "name": "嵌套 Column > Row 两级布局",
    "category": "layout",
    "complexity": "medium",
    "task": "生成两个组件：一个Extended.Column组件(id为page-root，children为[\"header-bar\", \"content-row\"])和一个Extended.Row组件(id为content-row，children为[\"sidebar\", \"main-area\"])",
    "expected": {
      "required_fields": ["id", "component"],
      "patterns": [
        {"field": "component", "must_contain": "Extended.Column"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "component", "description": "必须有component字段"},
      {"type": "contains", "field": "$output", "value": "Extended.Column", "description": "必须包含Extended.Column组件"},
      {"type": "contains", "field": "$output", "value": "Extended.Row", "description": "必须包含Extended.Row组件"},
      {"type": "contains", "field": "$output", "value": "content-row", "description": "Column的children应引用content-row"},
      {"type": "contains", "field": "$output", "value": "sidebar", "description": "Row的children应包含sidebar"}
    ],
    "hints": ["嵌套布局需要输出多个组件到components数组中", "外层Column通过children引用内层Row的id"]
  },
  {
    "id": "FP0209",
    "name": "三级布局树 Column > Row > Column",
    "category": "layout",
    "complexity": "complex",
    "task": "生成一个三级嵌套布局：最外层Extended.Column(id为app-root，children为[\"top-bar\", \"middle-row\"])，中间层Extended.Row(id为middle-row，children为[\"left-panel\", \"right-col\"])，最内层Extended.Column(id为right-col，children为[\"info-card\", \"action-bar\"])",
    "expected": {
      "required_fields": ["id", "component"],
      "patterns": [
        {"field": "component", "must_contain": "Extended.Column"}
      ]
    },
    "validation_rules": [
      {"type": "has_field", "field": "component", "description": "必须有component字段"},
      {"type": "contains", "field": "$output", "value": "Extended.Column", "description": "必须包含Extended.Column组件"},
      {"type": "contains", "field": "$output", "value": "Extended.Row", "description": "必须包含Extended.Row组件"},
      {"type": "contains", "field": "$output", "value": "app-root", "description": "必须包含app-root组件"},
      {"type": "contains", "field": "$output", "value": "middle-row", "description": "必须有middle-row组件作为中间层"},
      {"type": "contains", "field": "$output", "value": "right-col", "description": "必须有right-col组件作为最内层"}
    ],
    "hints": ["三级嵌套需要输出三个组件到components数组", "外层通过children引用内层组件的id", "注意层级关系：app-root > middle-row > right-col"]
  },
