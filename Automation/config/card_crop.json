{
  // 2x2 小卡片的裁切框，按开发者选项看到的像素坐标直接填写。
  // 格式：{ "x1": 左上角x, "y1": 左上角y, "x2": 右下角x, "y2": 右下角y }
  // 说明：x2/y2 是裁切右下角的边界坐标，程序会自动做边界修正。
  "crop_box_2x2": { "x1": 364, "y1": 97, "x2": 920, "y2": 577 },

  // 2x4 宽卡片的裁切框。
  "crop_box_2x4": { "x1": 95, "y1": 97, "x2": 1192, "y2": 577 },

  // 自动识别卡片类型时，用来判断内容宽度的检测框。
  // 这个框最好覆盖卡片内容最容易出现的区域，不要太窄。
  "detect_box": { "x1": 0, "y1": 97, "x2": 1280, "y2": 577 },

  // 自动判断卡片类型时使用的宽卡片阈值。
  // 检测到的内容宽度比例 >= 该值时按 2x4 处理，否则按 2x2 处理。
  "wide_card_threshold": 0.8,

  // 背景灰度阈值。像素灰度低于该值会被认为是前景内容。
  // 卡片内容漏检时可调高；把背景也当内容时可调低。
  "bg_gray_threshold": 235,

  // 有效内容块的最小宽度，单位像素。
  // 调大可过滤小噪点；调小可保留很窄的真实内容。
  "min_block_width": 50,

  // 横向内容块合并的最大间隙，单位像素。
  // 内容被拆得太碎可调大；多个区域被误合并可调小。
  "col_gap_threshold": 15,

  // 判断某一列存在内容的最小前景像素数。
  // 横向定位太敏感可调大；漏掉细线/小字可调小。
  "col_content_threshold": 3,

  // 判断某一行存在内容的最小前景像素数。
  // 纵向定位太敏感可调大；漏掉细线/小字可调小。
  "row_content_threshold": 2,

  // 卡片类型。可选值：
  // - "auto"：自动根据内容宽度判断 2x2 或 2x4。
  // - "2x2"：强制按 2x2 小卡片裁切。
  // - "2x4"：强制按 2x4 宽卡片裁切。
  "card_type": "auto"
}
