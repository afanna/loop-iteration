# Copy to config/aesthetic-v4.env, then fill the private key locally.
PANGU_BASE_URL=http://43.139.21.243:4000
PANGU_API_KEY=
PANGU_JUDGE_MODEL=claude-opus-4-7-thinking
# Use harmony-card-teacher-v1 for HarmonyOS card calibration.
# Set to aesthetic-v4 when you need the original baseline prompt.
PANGU_JUDGE_PROMPT_VERSION=harmony-card-teacher-v1
PANGU_JUDGE_OUTPUT_MODE=full
PANGU_JUDGE_TIMEOUT=360
PANGU_JUDGE_MAX_TOKENS=1200

# Ark / Doubao OpenAI-compatible backend.
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3
ARK_API_KEY=
ARK_JUDGE_MODEL=doubao-seed-2-0-lite
# Use harmony-card-teacher-v1 for HarmonyOS card calibration.
# Set to aesthetic-v4 when you need the original baseline prompt.
ARK_JUDGE_PROMPT_VERSION=harmony-card-teacher-v1
ARK_JUDGE_OUTPUT_MODE=full
ARK_JUDGE_TIMEOUT=360
ARK_JUDGE_MAX_TOKENS=1200

# Run controls.
AESTHETIC_V4_BACKEND=model
AESTHETIC_V4_MODEL_PROVIDER=ark
AESTHETIC_V4_WORKERS=1
AESTHETIC_V4_MANIFEST_VIEWPORT=all
AESTHETIC_V4_VIEWPORT=all
AESTHETIC_V4_VIEWPORT_SELECTION=auto
AESTHETIC_V4_AGGREGATE_STRATEGY=min
AESTHETIC_V4_SCREENSHOT_MODE=fullpage
AESTHETIC_V4_FULLPAGE_MAX_HEIGHT=12000
AESTHETIC_V4_ADAPTIVE_VIEWPORTS=on
AESTHETIC_V4_SCORE_BREAKDOWN=on
AESTHETIC_V4_DESIGNER_REVIEW=on
AESTHETIC_V4_FORMAL_REPORT=0
AESTHETIC_V4_OUTPUT_JSON=on
AESTHETIC_V4_OUTPUT_HTML=off

# Not configurable: occlusion/overlap checking is always on.
AESTHETIC_V4_OCCLUSION_OVERLAP_CHECK=always_on
