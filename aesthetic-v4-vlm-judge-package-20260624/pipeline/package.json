{
  "name": "aesthetic-v4-vlm-judge",
  "private": true,
  "type": "module",
  "scripts": {
    "run:mock": "bash run_aesthetic_v4.sh --mock",
    "run:model": "AESTHETIC_V4_MODEL_PROVIDER=ark bash run_aesthetic_v4.sh",
    "run:model:ark": "AESTHETIC_V4_MODEL_PROVIDER=ark bash run_aesthetic_v4.sh",
    "run:model:pangu": "AESTHETIC_V4_MODEL_PROVIDER=pangu bash run_aesthetic_v4.sh",
    "run:model:gpt55": "AESTHETIC_V4_MODEL_PROVIDER=pangu PANGU_JUDGE_MODEL=gpt-5.5 bash run_aesthetic_v4.sh",
    "run:model:gemini35": "AESTHETIC_V4_MODEL_PROVIDER=pangu PANGU_JUDGE_MODEL=gemini-3.5-flash bash run_aesthetic_v4.sh",
    "run:model:claude47": "AESTHETIC_V4_MODEL_PROVIDER=pangu PANGU_JUDGE_MODEL=claude-opus-4-7-thinking bash run_aesthetic_v4.sh",
    "manifest": "python3 scripts/build_html_manifest.py --input ../input_html --out ../runs/aesthetic-v4/manifest.jsonl --viewport all",
    "render": "node scripts/render_screenshots.mjs --manifest ../runs/aesthetic-v4/manifest.jsonl --out ../runs/aesthetic-v4/screenshots --viewport all --screenshot-on-timeout --capture-scroll-width --full-page --max-screenshot-css-height 12000",
    "report": "python3 scripts/build_aesthetic_v4_report.py --scores ../runs/aesthetic-v4/scores.jsonl --out ../runs/aesthetic-v4/report.html",
    "export:json": "python3 scripts/export_clean_html_score_json.py --scores ../runs/aesthetic-v4/scores.jsonl --out-dir ../outputs/json --index ../outputs/json/index.json",
    "manual-qc": "python3 scripts/build_manual_qc.py --index ../outputs/json/index.json --out ../manual_qc/index.html",
    "validate:json": "python3 scripts/validate_clean_json.py ../outputs/json/index.json"
  },
  "devDependencies": {
    "playwright": "1.60.0"
  }
}
